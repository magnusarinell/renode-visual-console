{
  // ── Renode GDB debug configurations ────────────────────────────
  // Prerequisites:
  //   1. Start Renode with the correct ELF loaded
  //      (npm start → web UI → pick scenario and ELF)
  //   2. GDB server starts automatically on the port listed below
  //   3. Press F5 and pick which program to debug
  //
  // Requires: marus25.cortex-debug extension
  // cppdbg is omitted — Cortex-Debug is a strict superset for ARM targets
  // (adds peripheral register browser, disassembly pane, memory viewer).
  //
  // Port map:
  //   3333 → Daisy (daisy_seed.resc)
  //   3334 → Nucleo board_0 (nucleo_dual.resc)
  //   3335 → Nucleo board_1 (nucleo_dual.resc)
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Daisy – Renode GDB",
      "type": "cortex-debug",
      "request": "attach",
      "servertype": "external",
      "gdbTarget": "localhost:3333",
      "executable": "${workspaceFolder}/submodules/DaisyExamples/seed/${input:daisyExample}/build/${input:daisyExample}.elf",
      "gdbPath": "${config:zephyrSdkPath}/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
      "objdumpPath": "${config:zephyrSdkPath}/arm-zephyr-eabi/bin/arm-zephyr-eabi-objdump",
      "cwd": "${workspaceFolder}",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    },
    {
      // Nucleo board_0 (Cortex-M4, Zephyr firmware)
      // ELF: zephyr/build/zephyr/zephyr.elf  (run npm run build:nucleo first)
      "name": "Nucleo board_0 – Renode GDB",
      "type": "cortex-debug",
      "request": "attach",
      "servertype": "external",
      "gdbTarget": "localhost:3334",
      "executable": "${workspaceFolder}/zephyr/build/zephyr/zephyr.elf",
      "gdbPath": "${config:zephyrSdkPath}/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
      "objdumpPath": "${config:zephyrSdkPath}/arm-zephyr-eabi/bin/arm-zephyr-eabi-objdump",
      "cwd": "${workspaceFolder}",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    },
    {
      // Nucleo board_1 (Cortex-M4, Zephyr firmware)
      "name": "Nucleo board_1 – Renode GDB",
      "type": "cortex-debug",
      "request": "attach",
      "servertype": "external",
      "gdbTarget": "localhost:3335",
      "executable": "${workspaceFolder}/zephyr/build/zephyr/zephyr.elf",
      "gdbPath": "${config:zephyrSdkPath}/arm-zephyr-eabi/bin/arm-zephyr-eabi-gdb",
      "objdumpPath": "${config:zephyrSdkPath}/arm-zephyr-eabi/bin/arm-zephyr-eabi-objdump",
      "cwd": "${workspaceFolder}",
      "runToEntryPoint": "main",
      "showDevDebugOutput": "none"
    }
  ],
  "inputs": [
    {
      "id": "daisyExample",
      "type": "pickString",
      "description": "Which Daisy seed example to debug?",
      "options": [
        "Blink",
        "Button",
        "Knob",
        "OLED",
        "bypass",
        "Drum",
        "DSP",
        "HWTest",
        "LCD_HD44780",
        "Logger",
        "Osc",
        "QSPI",
        "Ram",
        "ReceiveTest",
        "SDMMC",
        "USB_CDC",
        "USB_MIDI",
        "WavPlayer"
      ],
      "default": "Blink"
    }
  ]
}

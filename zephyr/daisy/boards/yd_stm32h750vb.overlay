/*
 * Overlay for yd_stm32h750vb targeting Renode simulation.
 *
 * The board's default flash-controller is the external W25Q128 QSPI NOR.
 * Override it to the internal STM32H7 flash controller so the ELF is linked
 * to run from 0x08000000 (flashBank1 in Renode's stm32h743.repl).
 */

/ {
    chosen {
        zephyr,flash-controller = &flash;
        zephyr,flash = &flash0;
    };
};

/* QuadSPI (external NOR flash) is not needed for simulation */
&quadspi {
    status = "disabled";
};

/* SD card not needed */
&sdmmc1 {
    status = "disabled";
};

/*
 * Clock override for Renode simulation.
 *
 * The default board clock tree uses HSE (25 MHz external oscillator) + PLL to
 * reach 480 MHz. Renode's simplified RCC model never sets HSERDY / PLL1RDY
 * after the HAL enables them, so Zephyr's clock init hangs in a busy-wait loop
 * and main() is never reached.
 *
 * Use the internal HSI64 (64 MHz, no external oscillator) directly as sysclk.
 * HSI is always ready in Renode's RCC model so the clock init completes instantly.
 */
&clk_hse {
    status = "disabled";
};

&clk_lse {
    status = "disabled";
};

&pll {
    status = "disabled";
};

&clk_hsi {
    status = "okay";
};

&rcc {
    clocks = <&clk_hsi>;
    clock-frequency = <64000000>;
    d1cpre = <1>;
    hpre = <1>;
    d1ppre = <1>;
    d2ppre1 = <1>;
    d2ppre2 = <1>;
    d3ppre = <1>;
};
